{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/onyx-notes/plugins/main/schema/registry-entry.schema.json",
  "title": "Onyx registry entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "author", "capabilities", "source"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 60 },
    "description": { "type": "string", "minLength": 1, "maxLength": 200 },
    "author": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 1,
      "items": {
        "enum": [
          "vault:read",
          "vault:write",
          "editor:read",
          "editor:write",
          "ui:commands",
          "ui:panel",
          "net:fetch"
        ]
      }
    },
    "source": {
      "type": "string",
      "pattern": "^https://raw\\.githubusercontent\\.com/onyx-notes/plugins/main/[a-z0-9-]+$"
    }
  }
}
